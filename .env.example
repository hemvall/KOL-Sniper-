# Safety: live trading is impossible until explicitly changed to false.
DRY_RUN=true

# Telegram signal source (create a NEW session after revoking the leaked one)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=data/sniper_session
TELEGRAM_CHANNELS=@channel_one,-1001234567890

# Solana wallet and network
PRIVATE_KEY=
RPC_URL=https://api.mainnet-beta.solana.com
RPC_SUBMIT_URLS=

# Official Pump SDK builder: isolated service in production, subprocess in development
BUILDER_MODE=local
ALLOW_BUILDER_FALLBACK=false
LOCAL_BUILDER_COMMAND=node tools/pump_builder.mjs
# Production: URL du builder isolé (Docker Compose le définit automatiquement)
LOCAL_BUILDER_URL=
PUMPPORTAL_URL=https://pumpportal.fun/api/trade-local

# Optional Helius Sender. TIP_ACCOUNT must be a current official Sender tip account.
HELIUS_SENDER_URL=
HELIUS_TIP_ACCOUNT=
SENDER_TIP_SOL=0.0002

# Execution and hard risk limits
BUY_AMOUNT_SOL=0.1
SLIPPAGE_BPS=1500
PRIORITY_FEE_SOL=0.0001
MAX_EXECUTION_FEE_SOL=0.01
MAX_TRANSACTION_TRANSFER_SOL=0.5
MAX_OPEN_POSITIONS=4
MAX_PENDING_ORDERS=2
MAX_TOTAL_EXPOSURE_SOL=1.0
MAX_DAILY_LOSS_SOL=0.25
MINT_COOLDOWN_SECONDS=86400
SIGNAL_CONCURRENCY=8
CONFIRM_TIMEOUT_SECONDS=25
RPC_TIMEOUT_SECONDS=3

# Durable exit strategy: target-multiple:fraction-of-original-position
EXIT_LADDER=2:0.25,3:0.25,5:0.25
STOP_LOSS_PCT=30
TRAILING_STOP_PCT=25
MAX_HOLD_SECONDS=3600
WEBSOCKET_STALE_SECONDS=20
RECONCILE_INTERVAL_SECONDS=2

# Operations
DATABASE_PATH=data/kol_sniper.db
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8787
LOG_LEVEL=INFO

# Optional notifications/read-only admin bot
NOTIFICATION_BOT_TOKEN=
NOTIFICATION_CHAT_ID=
ADMIN_USER_IDS=
